# ---- Kanban API configuration ----
# Copy to .env and fill in values before starting the server.

# Port the API listens on
PORT=4000

# Postgres connection. Leave UNSET to run with the in-memory store
# (zero-infra demo mode). Set it to enable the Postgres path.
# DATABASE_URL=postgres://kanban:kanban@db:5432/kanban

# Secret used to sign JWTs. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# CORS — the origin the web frontend is served from.
# Only requests from this origin are accepted (credentials included).
WEB_ORIGIN=http://localhost:8080

# Project-wide provisioning token. Authorises creating new agents and
# minting/rotating their tokens (POST /api/agents, POST /api/agents/:id/token)
# via the X-Provision-Token header. Leave UNSET to disable provisioning.
#   openssl rand -hex 32
PROVISION_TOKEN=replace-with-a-long-random-string
