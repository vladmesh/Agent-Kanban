# ============================================================
#  Kanban — root environment template
#  Copy to .env and fill in real values. Never commit .env.
# ============================================================

# Secret used to sign manager JWTs.
# Generate:  openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# The following vars are set by docker-compose for the container
# runtime and do not need to be in .env for normal Docker use:
#
#   DATABASE_URL=postgres://kanban:kanban@db:5432/kanban
#   WEB_ORIGIN=http://localhost:8080
#   PORT=4000
#
# Set them here only if you run the API outside Docker
# (e.g. `cd server && npm run dev` with a local Postgres).
